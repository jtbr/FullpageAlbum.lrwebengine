			-- 		f:labeled_text_input  {
			-- 			title = LOC "$$$/AgWPG/Templates/HTML/Panel/Labels/ScrollLeftDesc=Scroll Left Description (for mobile)",
			-- 			value = bind "nonCSS.text.ScrollLeftDesc",
