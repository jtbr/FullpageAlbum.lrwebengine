			-- 			value = bind "nonCSS.text.PreviousPageDesc",
			-- 		},
			-- 		f:labeled_text_input  {
			-- 			title = LOC "$$$/AgWPG/Templates/HTML/Panel/Labels/NextPageDesc=Next Page Description (for Desktops)",
