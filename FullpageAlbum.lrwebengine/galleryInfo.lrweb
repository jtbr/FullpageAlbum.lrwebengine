			-- 		},
			-- 		f:labeled_text_input  {
			-- 			title = LOC "$$$/AgWPG/Templates/HTML/Panel/Labels/NextPhotoShort=Next Photo (short for mobile)",
			-- 			value = bind "nonCSS.text.NextShort",
			-- 		},
			-- 		f:labeled_text_input  {
			-- 			title = LOC "$$$/AgWPG/Templates/HTML/Panel/Labels/NextPhotoDesc=Next Photo Description",
			-- 			value = bind "nonCSS.text.NextDesc",
			-- 		},
			-- 		f:labeled_text_input  {
			-- 			title = LOC "$$$/AgWPG/Templates/HTML/Panel/Labels/Slideshow=Slideshow",
			-- 			value = bind "nonCSS.text.Slideshow",
			-- 		},
			-- 		f:labeled_text_input  {
			-- 			title = LOC "$$$/AgWPG/Templates/HTML/Panel/Labels/SlideshowPlayDesc=Play Slideshow Description",
